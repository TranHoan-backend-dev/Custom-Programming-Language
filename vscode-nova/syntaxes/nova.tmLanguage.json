{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nova",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.nova"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.nova"
        }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.nova",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.nova"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(biáșżn|hĂ m|tráșŁ_vá»|náșżu|thĂŹ|cĂČn_náșżu|khĂŽng_thĂŹ|láș·p|duyá»t|cá»§a|tá»«|Äáșżn|Äáșżn_háșżt|dá»«ng|tiáșżp|trÆ°á»ng_há»Łp|sai|ÄĂșng|k_tá»n_táșĄi|kháșŁ_biáșżn|háș±ng_sá»|vĂ |hoáș·c|khĂŽng|khĂĄc|var|function|return|if|else|while|for|of|break|continue|switch|true|false|null|mut|const|and|or|not)\\b",
          "name": "keyword.control.nova"
        },
        {
          "match": "\\b(sá»_nguyĂȘn|chuá»i|logic|sá»_thá»±c_kĂ©p|trá»ng|int|string|boolean|double|void)\\b",
          "name": "entity.name.type.nova"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "match": "\\b(print|println|in|in_dĂČng_má»i|printf|in_Äá»nh_dáșĄng)\\b",
          "name": "support.function.nova"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.nova"
        }
      ]
    }
  },
  "scopeName": "source.nova"
}
